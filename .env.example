# Backend (apps/backend/.env)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
PORT=3001
CORS_ORIGIN=http://localhost:5173
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STORAGE_BUCKET=comprovantes
CRON_SECRET=change-me-cron-secret

# Frontend (apps/frontend/.env)
# Em dev local, aponta para o Express. Na Vercel, omita (usa /api/v1 no mesmo dominio).
VITE_API_URL=http://localhost:3001/api/v1

# Vercel (Project Settings > Environment Variables)
# Cole as mesmas variaveis do backend: JWT_SECRET, JWT_REFRESH_SECRET, SUPABASE_URL,
# SUPABASE_SERVICE_ROLE_KEY, STORAGE_BUCKET, CRON_SECRET, VAPID_* (opcional).
# CORS_ORIGIN=https://seu-dominio.vercel.app
# Nao defina VITE_API_URL na Vercel.
