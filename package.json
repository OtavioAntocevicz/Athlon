{
  "name": "athlon",
  "version": "1.7.1",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "pnpm --filter @athlon/shared-types build && pnpm run --parallel dev",
    "postinstall": "pnpm --filter @athlon/shared-types build",
    "dev:frontend": "pnpm --filter @athlon/frontend dev",
    "dev:backend": "pnpm --filter @athlon/backend dev",
    "build": "pnpm run --filter @athlon/shared-types build && pnpm run --filter @athlon/backend build && pnpm run --filter @athlon/frontend build",
    "build:vercel": "pnpm run --filter @athlon/shared-types build && pnpm run --filter @athlon/backend build && pnpm run --filter @athlon/frontend build",
    "test:db": "pnpm --filter @athlon/backend test:db",
    "seed:admin": "pnpm --filter @athlon/backend seed:admin",
    "test": "pnpm --filter @athlon/shared-types build && pnpm --filter @athlon/frontend test"
  },
  "dependencies": {
    "@athlon/backend": "workspace:*",
    "@athlon/shared-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4"
}
