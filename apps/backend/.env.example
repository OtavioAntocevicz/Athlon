JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
PORT=3001
CORS_ORIGIN=http://localhost:5173
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STORAGE_BUCKET=comprovantes
# Web Push (rode: pnpm generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@athlon.app
# Vercel Cron (gere um segredo aleatorio; a Vercel envia como Bearer automaticamente)
CRON_SECRET=
# Recuperação de senha (Resend - https://resend.com)
# Guia: docs/config-resend-web-push.md
RESEND_API_KEY=
EMAIL_FROM=ATHLON <onboarding@resend.dev>
APP_URL=http://localhost:5173
# Admin (seed inicial - rode: pnpm --filter @athlon/backend seed:admin)
ADMIN_EMAIL=admin@athlon.app
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NOME=Administrador
